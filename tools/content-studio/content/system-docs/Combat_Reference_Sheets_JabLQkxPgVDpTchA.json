    {
      "name": "Weapon Damage Chart",
      "type": "text",
      "text": {
        "format": 1,
        "content": "<p>This chart covers the primitive and low-tech weapons listed in the Gamma World core rules.</p><p>Damage is split by target size: small/man-sized versus large opponents.</p>\n    <div style=\"overflow-x:auto;margin:0.75rem 0\">\n      <table style=\"border-collapse:collapse;width:max-content;min-width:100%;font-size:0.92rem\">\n        \n        <thead><tr><th>Weapon</th><th>Small / Man-Sized</th><th>Large</th><th>Effective Range</th></tr></thead>\n        <tbody><tr><th scope=\"row\">Arrow</th><td>1d6</td><td>1d6</td><td>100</td></tr><tr><th scope=\"row\">Axe Battle</th><td>1d8</td><td>1d8</td><td>Melee</td></tr><tr><th scope=\"row\">Axe Hand</th><td>1d6</td><td>1d4</td><td>20</td></tr><tr><th scope=\"row\">Club</th><td>1d6</td><td>1d3</td><td>10</td></tr><tr><th scope=\"row\">Crossbow Bolt</th><td>1d4</td><td>1d4</td><td>120</td></tr><tr><th scope=\"row\">Dagger</th><td>1d4</td><td>1d3</td><td>20</td></tr><tr><th scope=\"row\">Flail</th><td>2d4-1</td><td>2d4</td><td>Melee</td></tr><tr><th scope=\"row\">Javelin</th><td>1d6</td><td>1d6</td><td>40</td></tr><tr><th scope=\"row\">Lance Mounted</th><td>1d6</td><td>1d10</td><td>Melee</td></tr><tr><th scope=\"row\">Mace</th><td>2d4-1</td><td>1d6</td><td>Melee</td></tr><tr><th scope=\"row\">Morning Star</th><td>2d4</td><td>2d4-1</td><td>Melee</td></tr><tr><th scope=\"row\">Pole Arm</th><td>1d8</td><td>1d12</td><td>Melee</td></tr><tr><th scope=\"row\">Sling Bullet</th><td>1d4+1</td><td>2d4-1</td><td>100</td></tr><tr><th scope=\"row\">Sling Stone</th><td>1d4</td><td>1d4</td><td>80</td></tr><tr><th scope=\"row\">Spear</th><td>1d6</td><td>1d8</td><td>20</td></tr><tr><th scope=\"row\">Sword Long</th><td>1d8</td><td>1d12</td><td>Melee</td></tr><tr><th scope=\"row\">Sword Short</th><td>1d6</td><td>1d8</td><td>Melee</td></tr><tr><th scope=\"row\">Sword Two Hand</th><td>1d10</td><td>3d6</td><td>Melee</td></tr></tbody>\n      </table>\n    </div>"
      },
