# Rulebook and other local-only reference materials (copyright)
ref/

# macOS
.DS_Store

# Claude Code local state
.claude/

# Editor state
.vscode/
.idea/
*.swp
*.swo

# Node (in case we ever add tooling)
node_modules/
npm-debug.log
__pycache__/
*.pyc

# Generated validation and working artifacts
output/
test-results/
tmp/

# Foundry compendium LevelDB lock files — written when a pack is open
# (by Foundry, by seal-packs.mjs, etc.) and NEVER belong in version
# control. A committed LOCK file can cause the pack to fail to open on
# another machine.
packs/*/LOCK
