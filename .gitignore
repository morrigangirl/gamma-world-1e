# Rulebook and other local-only reference materials (copyright)
ref/

# macOS
.DS_Store

# Claude Code local state
.claude/

# Editor state
.vscode/
.idea/
*.swp
*.swo

# Node (in case we ever add tooling)
node_modules/
npm-debug.log
__pycache__/
*.pyc

# Generated validation and working artifacts
output/
test-results/
tmp/

# Foundry compendium LevelDB lock files — written when a pack is open
# (by Foundry, by seal-packs.mjs, etc.) and NEVER belong in version
# control. A committed LOCK file can cause the pack to fail to open on
# another machine.
packs/*/LOCK

# LevelDB recovery quarantine. When LevelDB opens a pack and can't
# integrate some record, it moves it to packs/<name>/lost/ and
# continues. The artifact is always cosmetic for a freshly-built pack
# (we saw every lost/ folder hold a single 0-byte log file), but
# committing them preserves a "this pack was in a bad state once"
# signal that isn't useful to downstream consumers.
packs/*/lost/

# LevelDB operational trace logs. Human-readable audit of open/
# compact/close events written every time any tool (Foundry, seal-
# packs.mjs, classic-level) touches the DB. Content-free and rewritten
# on every pass — keeping them out of git avoids a seal-churn diff
# every time someone reseals. The numbered *.log files alongside (WAL)
# DO carry pack content and stay tracked.
packs/*/LOG
packs/*/LOG.old
