{{!--
  0.10.0 — reusable action-group row partial.

  Expected parameters (invoke with {{> ... items=... variant="attack"}}):
    items      Array of embedded item docs to render.
    variant    One of "attack" | "defense" | "utility" | "movement" | "buff" | "heal"
               — used as a CSS modifier on the row so each section can style
               differently.

  Layout fits inside the existing 2-column `.gamma-world__item` grid
  (body | actions). The icon lives INSIDE `.gamma-world__item-head` so
  it doesn't break the grid; explicit width/height keeps Foundry's
  512x512 default assets from rendering full-size.
--}}
<ul class="gamma-world__items gamma-world__action-list gamma-world__action-list--{{variant}}">
  {{#each items as |item|}}
    <li class="gamma-world__item draggable" data-item-id="{{item.id}}">
      <div class="gamma-world__item-body">
        <div class="gamma-world__item-head">
          {{#if item.img}}<img src="{{item.img}}" alt="" width="20" height="20" style="flex: 0 0 20px; width: 20px; height: 20px; object-fit: contain;" />{{/if}}
          <span class="gamma-world__item-name">{{#if item.gwDisplayName}}{{item.gwDisplayName}}{{else}}{{item.name}}{{/if}}</span>
          {{#each item.system.actionTypes as |tag|}}
            {{#unless (gwEq tag ../variant)}}
              <span class="gamma-world__badge gamma-world__badge--{{tag}}">{{tag}}</span>
            {{/unless}}
          {{/each}}
        </div>
        {{#if item.gwDetailLine}}
          <div class="gamma-world__item-meta">{{item.gwDetailLine}}</div>
        {{/if}}
      </div>
      <span class="gamma-world__item-actions">
        <button type="button" data-action="useItem" data-item-id="{{item.id}}" title="{{localize "GAMMA_WORLD.Button.Use"}}">
          <i class="fas fa-bolt"></i>
        </button>
      </span>
    </li>
  {{/each}}
</ul>
