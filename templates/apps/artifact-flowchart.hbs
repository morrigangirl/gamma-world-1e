<form class="gw-artifact-session">
  <header class="gw-artifact-session__header">
    <div class="gw-artifact-session__titleblock">
      <p class="gw-artifact-session__eyebrow">{{localize "GAMMA_WORLD.Artifact.Session.Title"}}</p>
      <h2>{{itemName}}</h2>
      <p class="gw-artifact-session__subhead">
        {{localize "GAMMA_WORLD.Artifact.Session.Operator"}}: {{operatorName}}
        {{#if actorName}} | {{actorName}}{{/if}}
        | Chart {{chartId}}
        | {{localize "GAMMA_WORLD.Artifact.Session.Rolls"}}: {{rollsThisAttempt}}
        | {{localize "GAMMA_WORLD.Artifact.Session.Time"}}: {{elapsedLabel}}
      </p>
    </div>
    <div class="gw-artifact-session__statusblock">
      <span class="gw-artifact-session__status">{{statusLabel}}</span>
      {{#if conditionVisible}}
        <span class="gw-artifact-session__condition">{{localize "GAMMA_WORLD.Artifact.Session.Condition"}}: {{conditionLabel}}</span>
      {{/if}}
      <span class="gw-artifact-session__modifier" title="{{modifierSummary}}">
        {{localize "GAMMA_WORLD.Artifact.Session.Modifier"}}: {{rollModifier}}
      </span>
    </div>
  </header>

  {{#if hasSession}}
    <div class="gw-artifact-session__body">
      <aside class="gw-artifact-session__legend-panel">
        <h3>{{localize "GAMMA_WORLD.Artifact.Session.ChartLegend"}}</h3>
        <ul class="gw-artifact-session__legend">
          {{#each legend as |entry|}}
            <li>{{entry}}</li>
          {{/each}}
        </ul>

        <section class="gw-artifact-session__controls">
          <h3>{{localize "GAMMA_WORLD.Artifact.Session.Controls"}}</h3>
          <div class="gw-artifact-session__button-grid">
            <button type="button" data-action="rollStep" {{#unless canRoll}}disabled{{/unless}}>
              {{#if isGM}}{{#unless isOperator}}{{localize "GAMMA_WORLD.Artifact.Session.ForceRoll"}}{{else}}{{localize "GAMMA_WORLD.Artifact.Session.Roll"}}{{/unless}}{{else}}{{localize "GAMMA_WORLD.Artifact.Session.Roll"}}{{/if}}
            </button>
            <button type="button" data-action="interruptSession" {{#unless canInterrupt}}disabled{{/unless}}>
              {{localize "GAMMA_WORLD.Artifact.Session.Interrupt"}}
            </button>
            <button type="button" data-action="tryArtifact" {{#unless canTry}}disabled{{/unless}}>
              {{localize "GAMMA_WORLD.Artifact.Session.TryItOut"}}
            </button>
            <button type="button" data-action="closeWindow">
              {{localize "GAMMA_WORLD.Artifact.Session.Close"}}
            </button>
          </div>

          <div class="gw-artifact-session__helper-controls">
            <label>{{localize "GAMMA_WORLD.Artifact.Session.Helpers"}}</label>
            <div class="gw-artifact-session__helper-row">
              <button type="button" data-action="changeHelpers" data-delta="-1" {{#unless canAdjustHelpers}}disabled{{/unless}}>-</button>
              <span>{{helperCount}}</span>
              <button type="button" data-action="changeHelpers" data-delta="1" {{#unless canAdjustHelpers}}disabled{{/unless}}>+</button>
            </div>
          </div>

          {{#if isGM}}
            <div class="gw-artifact-session__button-stack">
              <button type="button" data-action="reassignOperator" {{#unless canReassign}}disabled{{/unless}}>
                {{localize "GAMMA_WORLD.Artifact.Session.Reassign"}}
              </button>
              <button type="button" data-action="revealFunction" {{#unless canRevealFunction}}disabled{{/unless}}>
                {{localize "GAMMA_WORLD.Artifact.Session.RevealFunction"}}
              </button>
              <button type="button" data-action="revealOutcome" {{#unless canReveal}}disabled{{/unless}}>
                {{localize "GAMMA_WORLD.Artifact.Session.Reveal"}}
              </button>
              <button type="button" data-action="resetSession" {{#unless canReset}}disabled{{/unless}}>
                {{localize "GAMMA_WORLD.Artifact.Session.Reset"}}
              </button>
              <button type="button" data-action="toggleDebug">
                {{#if debugEnabled}}{{localize "GAMMA_WORLD.Artifact.Session.HideDebug"}}{{else}}{{localize "GAMMA_WORLD.Artifact.Session.ShowDebug"}}{{/if}}
              </button>
            </div>
          {{/if}}
        </section>

        {{#if publicOutcome}}
          <section class="gw-artifact-session__outcome">
            <h3>{{localize "GAMMA_WORLD.Artifact.Session.Observed"}}</h3>
            <p>{{publicOutcome}}</p>
          </section>
        {{/if}}
      </aside>

      <section class="gw-artifact-session__graph-panel">
        <div class="gw-artifact-session__graph-wrap">
          {{{graphSvg}}}
        </div>
      </section>

      <aside class="gw-artifact-session__history-panel">
        <section class="gw-artifact-session__latest">
          <h3>{{localize "GAMMA_WORLD.Artifact.Session.LatestRoll"}}</h3>
          {{#if latestRoll}}
            <p>{{latestRoll.summary}}</p>
          {{else}}
            <p>{{localize "GAMMA_WORLD.Artifact.Session.NoRollsYet"}}</p>
          {{/if}}
        </section>

        <section class="gw-artifact-session__history">
          <h3>{{localize "GAMMA_WORLD.Artifact.Session.History"}}</h3>
          <ol class="gw-artifact-session__history-list">
            {{#each history as |step|}}
              <li>
                #{{step.step}} | raw {{step.rawRoll}} | mod {{step.modifierLabel}} | adj {{step.adjustedRoll}} | {{step.from}} -> {{step.to}} | {{step.noteLabel}}
              </li>
            {{/each}}
          </ol>
        </section>

        {{#if gmDiagnostics.length}}
          <section class="gw-artifact-session__gm-panel">
            <h3>{{localize "GAMMA_WORLD.Artifact.Session.GmDiagnostics"}}</h3>
            <dl>
              {{#each gmDiagnostics as |entry|}}
                <div>
                  <dt>{{entry.label}}</dt>
                  <dd>{{entry.value}}</dd>
                </div>
              {{/each}}
            </dl>
          </section>
        {{/if}}
      </aside>
    </div>
  {{else}}
    <section class="gw-artifact-session__empty">
      <h3>{{localize "GAMMA_WORLD.Artifact.Session.Waiting"}}</h3>
      <p>{{localize "GAMMA_WORLD.Artifact.Session.WaitingHint"}}</p>
      <button type="button" data-action="closeWindow">{{localize "GAMMA_WORLD.Artifact.Session.Close"}}</button>
    </section>
  {{/if}}
</form>
