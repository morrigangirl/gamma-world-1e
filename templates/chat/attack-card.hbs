<div class="gw-chat-card gw-attack-card{{#if isCritical}} is-critical-hit{{/if}}{{#if isFumble}} is-critical-miss{{/if}}">
  <h3>{{weaponName}}</h3>
  <div class="gw-card-meta">
    {{actorName}} &rarr; {{targetName}}
    {{#if distance}}&middot; {{distance}} m{{/if}}
    {{#if rangeLabel}}&middot; {{localize "GAMMA_WORLD.Combat.Range"}} {{rangeLabel}}{{#if rangePenalty}} {{gwSigned rangePenalty}}{{/if}}{{/if}}
  </div>
  <div class="gw-card-meta">
    Target {{hitTarget}}+{{#if attackBonus}} &middot; bonus {{gwSigned attackBonus}}{{/if}}
    {{#if targetAc}}&middot; defense {{targetAc}}{{/if}}
  </div>
  <div class="gw-card-result {{#if hit}}is-hit{{else}}is-miss{{/if}}">
    Roll: {{d20}}{{#if total}}
      (total
      <button type="button"
              class="gw-roll-total"
              data-action="gw-toggle-roll"
              title="Click to expand the dice breakdown"
              aria-expanded="false">{{total}}</button>)
    {{/if}} &mdash;
    {{#if isCritical}}{{localize "GAMMA_WORLD.Combat.CriticalHit"}}
    {{else if isFumble}}{{localize "GAMMA_WORLD.Combat.CriticalMiss"}}
    {{else if hit}}HIT
    {{else}}MISS
    {{/if}}
  </div>
  {{#if rollTooltip}}
    <div class="gw-roll-breakdown" hidden>
      {{#if rollFormula}}<div class="gw-roll-breakdown__formula">{{rollFormula}}</div>{{/if}}
      {{{rollTooltip}}}
    </div>
  {{/if}}
  {{#if notes}}
    <div class="gw-card-meta">{{notes}}</div>
  {{/if}}
  {{#if hit}}
    {{#if showFollowUp}}
    <div class="gw-card-actions">
      <button type="button" data-action="gw-roll-damage">{{#if followUpLabel}}{{followUpLabel}}{{else}}Roll Damage{{/if}}</button>
    </div>
    {{/if}}
  {{/if}}
</div>
