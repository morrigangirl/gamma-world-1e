{
  "name": "gamma-world-1e",
  "version": "0.11.0",
  "type": "module",
  "scripts": {
    "legacy:build:compendia": "node scripts/build-compendia.mjs",
    "build:monster-prompts": "node scripts/build-monster-art-prompts.mjs",
    "build:monster-art": "python3 scripts/generate-art.py --category monsters",
    "build:monster-assets": "python3 scripts/render-assets.py --category monsters --shape portrait-token",
    "build:weapon-prompts": "node scripts/build-item-art-prompts.mjs --category weapons",
    "build:weapon-art": "python3 scripts/generate-art.py --category weapons",
    "build:weapon-assets": "python3 scripts/render-assets.py --category weapons --shape square-icon",
    "build:mutation-prompts": "node scripts/build-item-art-prompts.mjs --category mutations",
    "build:mutation-art": "python3 scripts/generate-art.py --category mutations",
    "build:mutation-assets": "python3 scripts/render-assets.py --category mutations --shape square-icon",
    "build:robot-prompts": "node scripts/build-item-art-prompts.mjs --category robots",
    "build:robot-art": "python3 scripts/generate-art.py --category robots",
    "build:robot-assets": "python3 scripts/render-assets.py --category robots --shape portrait-token",
    "audit:monster-art": "node scripts/monster-art-audit.mjs",
    "legacy:extract:rulebook-prose": "node scripts/extract-rulebook-prose.mjs",
    "legacy:import:rulebook-prose": "node scripts/import-rulebook-prose.mjs",
    "legacy:build:mutation-descriptions": "node scripts/build-mutation-descriptions.mjs",
    "legacy:prose:refresh": "npm run legacy:extract:rulebook-prose && npm run legacy:import:rulebook-prose && npm run legacy:build:mutation-descriptions && npm run legacy:build:compendia",
    "seal:packs": "node scripts/seal-packs.mjs",
    "test": "node --test",
    "test:foundry": "node scripts/foundry-smoke.mjs",
    "test:foundry:phase2": "node scripts/foundry-phase2.mjs",
    "test:foundry:phase3": "node scripts/foundry-phase3.mjs"
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "playwright": "^1.59.1"
  }
}
